# ── Sol-Core connection (SERVER-SIDE — never shipped to the browser) ─────────
# Gaming API base URL (canonical).
SOLCORE_API_URL=https://api.sol-core.com
# Your game API key (shown once in the creator dashboard). SECRET.
SOLCORE_API_KEY=sk_live_YOUR_KEY
# Your game's UUID (creator dashboard).
SOLCORE_GAME_ID=YOUR_GAME_ID

# ── Public (browser) ────────────────────────────────────────────────────────
NEXT_PUBLIC_GAME_NAME=My Game

# Engine + mechanic. Must match how the game was registered (see docs/ENGINES.md):
#   single engines: coin-flip, dice, crash, limbo, mines, hilo, plinko,
#                   wheel, keno, scratch, roulette, slots-3x3
#   session engines: mines, hilo, towers, pump
#   tournament engines: gauntlet (pot-based highscore cycles)
NEXT_PUBLIC_ENGINE=crash
NEXT_PUBLIC_MECHANIC=single

# Solana RPC + program for on-chain deposits (devnet).
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=8R7PfDa6FYVZdYgg7mGD8kfXNRN66M9VenLjP1t2qaoG

# Optional: Akzentfarbe deines Spiels als Hex (Re-Skin ohne Code).
# NEXT_PUBLIC_ACCENT_COLOR=#14F195
